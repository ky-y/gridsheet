{
    "name": "@ky-y./gridsheet",
    "version": "0.0.3",
    "description": "",
    "keywords": [
        "react",
        "react-component",
        "grid",
        "gridsheet",
        "spreadsheet",
        "table",
        "datagrid",
        "data-grid",
        "editable-table",
        "cell",
        "typescript"
    ],
    "author": {
        "name": "ky-y.",
        "url": "https://ky-y.dev/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ky-y/gridsheet.git"
    },
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite -c vite.playground.config.ts",
        "build": "tsc --noEmit && vite build",
        "scss:generate": "typed-scss-modules src --exportType default --nameFormat none --allowArbitraryExtensions",
        "scss:watch": "typed-scss-modules src --exportType default --nameFormat none --allowArbitraryExtensions --watch",
        "test": "vitest",
        "format": "biome format --write",
        "format:check": "biome format",
        "lint": "biome lint --write",
        "lint:check": "biome lint",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@chromatic-com/storybook": "^5.0.1",
        "@storybook/addon-a11y": "^10.2.16",
        "@storybook/addon-docs": "^10.2.16",
        "@storybook/addon-onboarding": "^10.2.16",
        "@storybook/addon-vitest": "^10.2.16",
        "@storybook/react-vite": "^10.2.16",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.3.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/browser-playwright": "4.0.18",
        "@vitest/coverage-v8": "4.0.18",
        "jsdom": "^28.1.0",
        "playwright": "^1.58.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sass": "^1.97.3",
        "storybook": "^10.2.16",
        "typed-scss-modules": "^8.1.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "packageManager": "pnpm@10.28.2"
}
